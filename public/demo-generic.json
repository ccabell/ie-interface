          "cardType": "summary",
          "grid": { "xs": 12, "md": 8 },
          "props": {
            "title": "Summary",
            "description": "This is a general summary text block. It can contain any description, analysis, or narrative content. The card adapts to whatever content you provide."
          }
        },
        {
          "cardType": "valueAccordion",
          "grid": { "xs": 12, "md": 4 },
          "props": { "title": "Confidence", "value": 78 }
        }
      ]
